# PostgreSQL Database Configuration
# Used by docker-compose.yml to set up the DB
PG_USER=
PG_PASSWORD=
PG_DATABASE=

# Database Connection URL
# Used by SQLModel to connect to the database (defaults to the local docker instance if unset)
DATABASE_URL=

# Quran Foundation API & OAuth URLs
# Defaults to pre-live environments if unset in code, but configured here for production.
QF_AUTH_BASE_URL=
QF_API_BASE_URL=

# Quran Foundation OAuth Credentials
# You get these from your approved application at https://api-docs.quran.foundation/request-access/
QF_CLIENT_ID=your_client_id_here
QF_CLIENT_SECRET=your_client_secret_here
